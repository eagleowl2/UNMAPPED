# Vite proxy target. The SPA itself always fetches relative `/api/v1/*`
# URLs in the browser; the Vite dev-server (or a production reverse-proxy)
# forwards them to this target.
#
# - Standalone dev (backend on host):    VITE_API_URL=http://localhost:8000
# - docker-compose (set in compose.yml): VITE_API_URL=http://backend:8000
# - Pure offline / mock-only demo:       leave unset, set VITE_DEMO_MODE=true
VITE_API_URL=http://localhost:8000

# When true, the SPA never calls the backend and uses the bundled mock.
# Useful for the conference-wifi pitch.
VITE_DEMO_MODE=false

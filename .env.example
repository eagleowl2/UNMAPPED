# UNMAPPED SSE — backend environment variables
# Copy to .env and edit as needed for local development WITHOUT Docker.
# docker-compose.yml sets these automatically for container runs.

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Comma-separated list of allowed CORS origins (no trailing slash, no spaces).
# Add your frontend origin if running on a different port.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# --- Multilingual Embedder ---
# Default: intfloat/multilingual-e5-small (~118 MB, CPU-only, 100+ languages)
# Production GPU upgrade: set to BAAI/bge-m3
UNMAPPED_EMBED_MODEL=intfloat/multilingual-e5-small

# Set to 1 to skip the embedding stage entirely (alias_registry + regex only).
# Useful for dev when you don't want the model download.
# UNMAPPED_EMBED_DISABLE=1

# Similarity threshold for semantic paraphrase matching (0.0–1.0).
# Lower = more matches (more noise); higher = stricter (fewer misses).
# UNMAPPED_EMBED_THRESHOLD=0.74

# HuggingFace cache directory (optional — defaults to ~/.cache/huggingface).
# HF_HOME=/tmp/hf_cache
